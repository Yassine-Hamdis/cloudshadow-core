# ─── MySQL ────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=rootpassword123
MYSQL_DATABASE=cloudShadowdb
MYSQL_USER=cloudshadow_user
MYSQL_PASSWORD=cloudshadow123

# ─── Backend Database Connection ──────────────────────────────────────────
DB_URL=jdbc:mysql://cloudshadow-mysql:3306/cloudShadowdb?createDatabaseIfNotExist=true
DB_USERNAME=cloudshadow_user
DB_PASSWORD=cloudshadow123

# ─── JWT ──────────────────────────────────────────────────────────────────
JWT_SECRET=cloudshadow-super-secret-key-must-be-at-least-256-bits-long!!
JWT_EXPIRATION=86400000

# ─── URLs (using container names not localhost) ───────────────────────────
BACKEND_URL=http://cloudshadow-backend:8080
AI_SERVICE_URL=http://cloudshadow-ai:8000

# ─── Agent ────────────────────────────────────────────────────────────────
# Get this token after creating a server in the dashboard
AGENT_SERVER_TOKEN=fc5b9dd39d1449b0924806a4cdb47a51
AGENT_INTERVAL=20
